# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://searchuser:searchpass@localhost:5432/semantic_search
SYNC_DATABASE_URL=postgresql://searchuser:searchpass@localhost:5432/semantic_search

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Models ─────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=google/flan-t5-large

# ── MLflow ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=200
CHUNK_OVERLAP=30
TOP_K=5

# ── Auth ──────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── App ───────────────────────────────────────────────────
UPLOAD_DIR=./uploads
LOG_LEVEL=INFO
